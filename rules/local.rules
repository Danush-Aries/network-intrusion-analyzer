# Suricata Local Detection Rules
# Network Intrusion Alert Analyzer - Detection Rule Set
# Covers: Port Scan, SQL Injection, XSS, Brute Force, C2 Beacon, DNS Tunneling, and more

# ============================================================
# Rule 1: TCP SYN Port Scan Detection
# Detects rapid SYN packets to multiple ports (classic Nmap-style scan)
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ET SCAN Possible TCP SYN Port Scan"; flags:S,12; threshold:type both, track by_src, count 20, seconds 5; classtype:network-scan; sid:9000001; rev:3; metadata:affected_product Any, attack_target Server, created_at 2023_01_01, cve CVE-2023-1234, deployment Perimeter, signature_severity Major, tag Reconnaissance;)

# ============================================================
# Rule 2: SQL Injection - UNION SELECT Attack
# Detects classic SQL injection union-based enumeration
# ============================================================
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ET WEB_SERVER SQL Injection - UNION SELECT Attempt"; flow:established,to_server; content:"UNION"; nocase; http_uri; content:"SELECT"; nocase; http_uri; distance:0; within:20; pcre:"/UNION[\s\+\/\*]+ALL[\s\+\/\*]+SELECT|UNION[\s\+\/\*]+SELECT/Ui"; classtype:web-application-attack; sid:9000002; rev:5; metadata:affected_product Web_Server_Applications, attack_target Web_Server, created_at 2023_01_01, cve CVE-2023-21839, deployment Datacenter, signature_severity Critical, tag SQLi;)

# ============================================================
# Rule 3: Cross-Site Scripting (XSS) - Script Tag Injection
# Detects <script> tag injection in HTTP parameters
# ============================================================
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ET WEB_SERVER XSS - Script Tag in URI"; flow:established,to_server; content:"<script"; nocase; http_uri; pcre:"/<script[\s>]/Ui"; classtype:web-application-attack; sid:9000003; rev:4; metadata:affected_product Web_Server_Applications, attack_target Web_Server, created_at 2023_01_01, deployment Datacenter, signature_severity High, tag XSS;)

# ============================================================
# Rule 4: SSH Brute Force Attack Detection
# Detects rapid failed SSH authentication attempts
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"ET BRUTE SSH Brute Force Login Attempt"; flow:established,to_server; content:"SSH-"; depth:4; threshold:type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000004; rev:3; metadata:affected_product SSH_Server, attack_target Server, created_at 2023_01_01, deployment Perimeter, signature_severity High, tag BruteForce;)

# ============================================================
# Rule 5: Command and Control (C2) Beacon - Periodic HTTP Check-in
# Detects beacon-like periodic HTTP requests to suspicious hosts
# ============================================================
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET MALWARE Possible C2 Beacon - Periodic HTTP Check-in"; flow:established,to_server; content:"User-Agent|3a 20|Mozilla/4.0 (compatible"; http_header; content:"GET"; http_method; pcre:"/\/[a-z0-9]{8,12}\.(php|aspx|jsp)\?[a-z]{1,4}=[a-z0-9]{8,32}/U"; threshold:type both, track by_src, count 5, seconds 300; classtype:trojan-activity; sid:9000005; rev:4; metadata:affected_product Windows, attack_target Client_Endpoint, created_at 2023_01_01, deployment SSLDecrypt, signature_severity Critical, tag C2;)

# ============================================================
# Rule 6: DNS Tunneling - Long DNS Query Detection
# Detects unusually long DNS queries used for data exfiltration
# ============================================================
alert dns $HOME_NET any -> any 53 (msg:"ET POLICY DNS Tunneling - Excessively Long DNS Query"; dns.query; content:"."; pcre:"/^[a-z0-9]{50,}(\.[a-z0-9]{1,63}){1,5}\.[a-z]{2,6}$/"; classtype:policy-violation; sid:9000006; rev:2; metadata:affected_product Windows, attack_target Any, created_at 2023_01_01, deployment Internal, signature_severity Medium, tag DNSTunnel;)

# ============================================================
# Rule 7: FTP Brute Force - Multiple AUTH Failures
# Detects FTP authentication brute force attempts
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"ET BRUTE FTP Brute Force Login Attempt"; flow:established,to_server; content:"PASS "; nocase; threshold:type both, track by_src, count 15, seconds 60; classtype:attempted-admin; sid:9000007; rev:2; metadata:affected_product FTP_Server, attack_target Server, created_at 2023_01_01, deployment Perimeter, signature_severity High, tag BruteForce;)

# ============================================================
# Rule 8: Exploit - Log4Shell (CVE-2021-44228) JNDI Injection
# Detects Log4Shell exploitation attempt in HTTP headers
# ============================================================
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ET EXPLOIT Apache Log4j RCE Attempt (CVE-2021-44228)"; flow:established,to_server; content:"${jndi:"; nocase; http_header; pcre:"/\$\{jndi:(ldap|rmi|dns|iiop|corba|nis)s?:\/\//Hi"; classtype:attempted-admin; sid:9000008; rev:6; metadata:affected_product Apache_Log4j, attack_target Server, created_at 2021_12_09, cve CVE-2021-44228, deployment Datacenter, signature_severity Critical, tag Log4Shell;)

# ============================================================
# Rule 9: Data Exfiltration - Large ICMP Packet (ICMP Tunnel)
# Detects ICMP tunneling via abnormally large ICMP echo requests
# ============================================================
alert icmp $HOME_NET any -> $EXTERNAL_NET any (msg:"ET POLICY ICMP Large Packet Possible Tunnel/Exfiltration"; itype:8; dsize:>1000; threshold:type both, track by_src, count 3, seconds 60; classtype:policy-violation; sid:9000009; rev:2; metadata:affected_product Any, attack_target Any, created_at 2023_01_01, deployment Perimeter, signature_severity Medium, tag Exfil;)

# ============================================================
# Rule 10: Ransomware - SMB Lateral Movement (EternalBlue-style)
# Detects SMB exploitation attempts targeting MS17-010
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"ET EXPLOIT EternalBlue SMB Remote Code Execution (MS17-010)"; flow:established,to_server; content:"|FF|SMB"; depth:5; offset:4; content:"|73 00|"; distance:0; within:200; pcre:"/\xff\x53\x4d\x42.{12,16}\x73\x00/s"; classtype:attempted-admin; sid:9000010; rev:5; metadata:affected_product Windows_SMB, attack_target Server, created_at 2017_04_14, cve CVE-2017-0144, deployment Perimeter, signature_severity Critical, tag EternalBlue;)
